---
import { faHashtag } from "@fortawesome/free-solid-svg-icons";
import FAIcon from "@/components/FAIcon.astro";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "flex items-center gap-0.5",
      "border-foreground border-b-2 border-dashed",
      "hover:border-accent hover:text-accent hover:-mt-0.5",
      "focus-visible:text-accent focus-visible:border-none",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <FAIcon icon={faHashtag}
      class:list={[
        "opacity-80",
        { "size-4": size === "lg" },
        { "size-3": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
