---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { faArrowLeft, faArrowRight } from "@fortawesome/free-solid-svg-icons";
import FAIcon from "@/components/FAIcon.astro";
import LinkButton from "./LinkButton.astro";

type Props = {
  page: Page<CollectionEntry<"posts">>;
};

const { page } = Astro.props;
---

{
  page.lastPage > 1 && (
    <nav
      class="mt-auto mb-8 flex justify-center gap-4"
      role="navigation"
      aria-label="Pagination Navigation"
    >
      <LinkButton
        disabled={!page.url.prev}
        href={page.url.prev as string}
        class:list={["select-none", { "opacity-50": !page.url.prev }]}
        aria-label="前往上一页"
      >
        <FAIcon icon={faArrowLeft} class="inline-block rtl:rotate-180" />
        上一页
      </LinkButton>
      {page.currentPage} / {page.lastPage}
      <LinkButton
        disabled={!page.url.next}
        href={page.url.next as string}
        class:list={["select-none", { "opacity-50": !page.url.next }]}
        aria-label="前往下一页"
      >
        下一页
        <FAIcon icon={faArrowRight} class="inline-block rtl:rotate-180" />
      </LinkButton>
    </nav>
  )
}
