---
import config from "@/config";
import LinkButton from "./LinkButton.astro";
import { socialIconMap } from "@/utils/iconMap";
import FAIcon from "@/components/FAIcon.astro";

const { site, socials } = config;

const items = socials.map(({ name, url, linkTitle }) => {
    const icon = socialIconMap[name];
    const title =
        linkTitle ??
        (url.startsWith("mailto:") || name === "mail"
            ? `Send an email to ${site.title}`
            : `${site.title} on ${name.charAt(0).toUpperCase() + name.slice(1)}`);
    return { url, title, icon };
});
---

<div class="flex flex-wrap items-center gap-1">
    {
        items.map(({ url, title, icon }) =>
            icon ? (
                <LinkButton
                    href={url}
                    class="p-2 hover:rotate-6 sm:p-1"
                    title={title}
                >
                    <FAIcon
                        icon={icon}
                        class="inline-block size-6 scale-125 opacity-90 sm:scale-110"
                    />
                    <span class="sr-only">{title}</span>
                </LinkButton>
            ) : null
        )
    }
</div>
